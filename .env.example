# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.

# Supabase Project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon Key — safe to use client-side, but keep RLS enabled
# (found in: Supabase Dashboard → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key — SERVER ONLY. Never expose this to the client.
# Never prefix with VITE_. Used only in api/ serverless functions.
# (found in: Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
